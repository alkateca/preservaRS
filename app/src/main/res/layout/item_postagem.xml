<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/margin_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/margin_medium">

        <ImageView
            android:id="@+id/imgPostagem"
            android:layout_width="match_parent"
            android:layout_height="@dimen/post_image_height"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Imagem da postagem" />

        <TextView
            android:id="@+id/txtTituloPostagem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/itemPostagemTitulo"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/margin_small"
            app:layout_constraintTop_toBottomOf="@id/imgPostagem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/txtDescricaoPostagem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/itemPostagemDescricao"
            android:textSize="@dimen/text_size_body"
            android:layout_marginTop="@dimen/margin_tiny"
            app:layout_constraintTop_toBottomOf="@id/txtTituloPostagem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/btnEmail"
            android:layout_width="@dimen/min_touch_target"
            android:layout_height="@dimen/min_touch_target"
            android:src="@android:drawable/ic_dialog_email"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginTop="@dimen/margin_small"
            android:layout_marginEnd="@dimen/margin_small"
            app:layout_constraintTop_toBottomOf="@id/txtDescricaoPostagem"
            app:layout_constraintEnd_toStartOf="@id/btnEditar"
            android:contentDescription="Enviar por Email" />

        <ImageButton
            android:id="@+id/btnEditar"
            android:layout_width="@dimen/min_touch_target"
            android:layout_height="@dimen/min_touch_target"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginTop="@dimen/margin_small"
            app:layout_constraintTop_toBottomOf="@id/txtDescricaoPostagem"
            app:layout_constraintEnd_toStartOf="@id/btnExcluir"
            android:layout_marginEnd="@dimen/margin_small"
            android:contentDescription="Editar" />

        <ImageButton
            android:id="@+id/btnExcluir"
            android:layout_width="@dimen/min_touch_target"
            android:layout_height="@dimen/min_touch_target"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginTop="@dimen/margin_small"
            app:layout_constraintTop_toBottomOf="@id/txtDescricaoPostagem"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="Excluir" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>